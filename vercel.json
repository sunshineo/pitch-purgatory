{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/ideas",
      "destination": "/index.html"
    },
    {
      "source": "/ideas/:path*",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/judge.js": {
      "maxDuration": 60
    }
  }
}
